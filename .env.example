# .env.example — Wolf Trading SaaS
# Copier en .env et remplir les valeurs
# ⚠️ TOUS les secrets doivent être changés en production!

# Server
PORT=3001
NODE_ENV=development
APP_URL=https://wolf.trading
CLIENT_URL=http://localhost:5173

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/wolf

# Auth — OBLIGATOIRE, minimum 32 caractères, aléatoire
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGEZ_MOI_MINIMUM_32_CARACTERES_ALEATOIRES

# Encryption des clés API Alpaca — OBLIGATOIRE, exactement 32 caractères
# Générer avec: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=CHANGEZ_MOI_EXACTEMENT_32_CHARS!!

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# Email (Resend)
RESEND_API_KEY=re_...

# Telegram (optionnel — notifications de trades)
# Créer un bot via @BotFather sur Telegram pour obtenir le token
TELEGRAM_BOT_TOKEN=

# Kill switch — mettre "true" pour bloquer tous les trades
WOLF_KILL_SWITCH=false
