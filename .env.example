# .env.example — Wolf Trading SaaS
# Copier en .env et remplir les valeurs

# Server
PORT=3001
NODE_ENV=development
APP_URL=https://wolf.trading
CLIENT_URL=http://localhost:5173

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/wolf

# Auth
JWT_SECRET=change-me-min-32-chars-random-string
ENCRYPT_KEY=change-me-exactly-32-chars-here!!

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# Email (Resend)
RESEND_API_KEY=re_...
