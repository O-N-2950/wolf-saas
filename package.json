{
  "name": "wolf-of-wall-street-saas",
  "version": "1.0.0",
  "description": "Wolf Trading — Automated defense & aerospace trading bot SaaS",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon --exec tsx server/index.ts",
    "client": "vite client",
    "build": "tsc && vite build client",
    "start": "node dist/server/index.js",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.30.0",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "stripe": "^17.0.0",
    "resend": "^3.2.0",
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "node-cron": "^3.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.11.0",
    "@types/cors": "^2.8.17",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "nodemon": "^3.0.3",
    "drizzle-kit": "^0.20.14",
    "vite": "^5.0.12",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.17"
  }
